{
    "name": "zarbinco/laravel-vandar",
    "description": "An unofficial Laravel SDK for Vandar APIs.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/zarbinco/laravel-vandar",
    "keywords": [
        "laravel",
        "vandar",
        "payment",
        "ipg",
        "settlement",
        "iban",
        "card",
        "inquiry",
        "sdk",
        "iran"
    ],
    "support": {
        "issues": "https://github.com/zarbinco/laravel-vandar/issues",
        "source": "https://github.com/zarbinco/laravel-vandar"
    },
    "authors": [
        {
            "name": "Zarbinco"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/cache": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/encryption": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "laravel/pint": "^1.18"
    },
    "autoload": {
        "psr-4": {
            "Zarbinco\\LaravelVandar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zarbinco\\LaravelVandar\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zarbinco\\LaravelVandar\\LaravelVandarServiceProvider"
            ],
            "aliases": {
                "Vandar": "Zarbinco\\LaravelVandar\\Facades\\Vandar"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint",
        "format:test": "vendor/bin/pint --test",
        "analyse": "phpstan analyse --memory-limit=1G",
        "phpstan": "@analyse",
        "audit:release": "php scripts/audit-release.php",
        "ci": [
            "@format:test",
            "@analyse",
            "@test",
            "@audit:release"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
